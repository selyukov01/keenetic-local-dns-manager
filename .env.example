# Keenetic DNS Manager Configuration
# Copy this file to .env.local and configure your values

# ===========================================
# APP MODE (required)
# ===========================================
# demo    - Public demo mode. Router credentials entered in browser,
#           stored in sessionStorage. No server-side secrets needed.
# no-auth - Open access. Router credentials from env, no user login.
# auth    - Protected access. Requires login, router credentials from env.
APP_MODE=demo

# ===========================================
# KEENETIC ROUTER (required for no-auth/auth modes)
# ===========================================
# In demo mode these are ignored - users enter credentials in browser
KEENETIC_HOST=192.168.1.1
KEENETIC_LOGIN=admin
KEENETIC_PASSWORD=your_router_password

# Save router session cookies to file (data/keenetic-cookies.json).
# Speeds up requests by reusing session instead of re-authenticating.
# Only works in no-auth/auth modes.
KEENETIC_COOKIE_PERSIST=false

# ===========================================
# AUTHENTICATION (required for auth mode)
# ===========================================
# Credentials for app login (not router!)
AUTH_LOGIN=admin
AUTH_PASSWORD=your_secure_password

# JWT secret for session tokens (min 32 characters)
# Generate with: openssl rand -base64 32
AUTH_JWT_SECRET=your-32-character-secret-key-here

# ===========================================
# PROMETHEUS METRICS (optional)
# ===========================================
METRICS_ENABLED=true

# Optional Basic Auth protection for /metrics endpoint
METRICS_AUTH_ENABLED=false
METRICS_AUTH_LOGIN=prometheus
METRICS_AUTH_PASSWORD=metrics_password

# ===========================================
# LOGGING (optional)
# ===========================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: json (production) or pretty (development)
LOG_FORMAT=pretty
